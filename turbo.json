{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "public/build/**",
                "build/**"
            ]
        },
        "lint": {},
        "test": {},
        "typecheck": {
            "inputs": [
                "**/*.ts",
                "**/*.tsx",
                "tsconfig.json"
            ],
            "outputs": [
                "node_modules/.cache/tsbuildinfo"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}